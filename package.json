{
  "name": "jobops-showcase",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A safety-aware, auditable job-search operations agent built with Codex and GPT-5.6.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --test tests/*.test.mjs",
    "privacy:check": "node scripts/privacy-check.mjs",
    "verify": "npm run test && npm run privacy:check && npm run build",
    "demo:record": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/build-demo-video.ps1"
  },
  "dependencies": {
    "next": "^15.5.20",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "playwright": "^1.61.1",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=20"
  }
}
